<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FAFAFA"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explore Indonesian Food 🍜"
            android:textStyle="bold"
            android:textSize="24sp"
            android:textColor="#000000"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Discover delicious traditional recipes"
            android:textSize="14sp"
            android:textColor="#777777"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="18dp"/>

        <!-- CARD 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="10dp"
            android:layout_marginBottom="18dp"
            android:elevation="3dp">

            <ImageView
                android:id="@+id/imgExplore1"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:scaleType="centerCrop"
                android:src="@drawable/nasi_kuning"
                android:background="@drawable/rounded_img"
                android:clipToOutline="true"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtExploreTitle1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nasi Kuning Nusantara"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#000"/>

                    <TextView
                        android:id="@+id/txtExploreAuthor1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="By Chef Indonesia"
                        android:textSize="13sp"
                        android:textColor="#888"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 4.9"
                    android:textStyle="bold"
                    android:textColor="#FFA200"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nasi kuning khas Indonesia dengan aroma santan yang gurih."
                android:textSize="13sp"
                android:textColor="#666"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- CARD 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="10dp"
            android:layout_marginBottom="18dp"
            android:elevation="3dp">

            <ImageView
                android:id="@+id/imgExplore2"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:scaleType="centerCrop"
                android:src="@drawable/rendang"
                android:background="@drawable/rounded_img"
                android:clipToOutline="true"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtExploreTitle2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rendang Padang"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#000"/>

                    <TextView
                        android:id="@+id/txtExploreAuthor2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="By Dapur Minang"
                        android:textSize="13sp"
                        android:textColor="#888"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 5.0"
                    android:textStyle="bold"
                    android:textColor="#FFA200"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daging rendang empuk dengan bumbu rempah khas Padang."
                android:textSize="13sp"
                android:textColor="#666"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- CARD 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="10dp"
            android:layout_marginBottom="18dp"
            android:elevation="3dp">

            <ImageView
                android:id="@+id/imgExplore3"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:scaleType="centerCrop"
                android:src="@drawable/gudeg"
                android:background="@drawable/rounded_img"
                android:clipToOutline="true"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtExploreTitle3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gudeg Jogja"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#000"/>

                    <TextView
                        android:id="@+id/txtExploreAuthor3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="By Kuliner Jawa"
                        android:textSize="13sp"
                        android:textColor="#888"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 4.8"
                    android:textStyle="bold"
                    android:textColor="#FFA200"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gudeg manis khas Yogyakarta dengan ayam dan telur."
                android:textSize="13sp"
                android:textColor="#666"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- CARD 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="10dp"
            android:layout_marginBottom="18dp"
            android:elevation="3dp">

            <ImageView
                android:id="@+id/imgExplore4"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:scaleType="centerCrop"
                android:src="@drawable/sate_ayam"
                android:background="@drawable/rounded_img"
                android:clipToOutline="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sate Ayam Madura"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sate ayam dengan bumbu kacang khas Madura."
                android:textSize="13sp"
                android:textColor="#666"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- CARD 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="10dp"
            android:elevation="3dp">

            <ImageView
                android:id="@+id/imgExplore5"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:scaleType="centerCrop"
                android:src="@drawable/soto_ayam"
                android:background="@drawable/rounded_img"
                android:clipToOutline="true"/>

            <TextView
                android:id="@+id/txtExploreTitle5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Soto Ayam Lamongan"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/txtExploreAuthor5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="By Dapur Nusantara"
                android:textSize="13sp"
                android:textColor="#888"
                android:layout_marginTop="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kuah gurih dengan suwiran ayam khas Lamongan."
                android:textSize="13sp"
                android:textColor="#666"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>